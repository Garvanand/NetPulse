# ── NetPulse Environment Configuration ──────────────────────────────
# Copy this file to .env and fill in your values.
# All variables are prefixed with NETPULSE_ in the environment.

# ── App ─────────────────────────────────────────────────────────────
NETPULSE_ENVIRONMENT=development
NETPULSE_DEBUG=true
NETPULSE_LOG_LEVEL=INFO

# ── Database (PostgreSQL + TimescaleDB) ─────────────────────────────
NETPULSE_DATABASE_URL=postgresql+asyncpg://netpulse:netpulse@localhost:5432/netpulse

# ── Redis ───────────────────────────────────────────────────────────
NETPULSE_REDIS_URL=redis://localhost:6379/0

# ── JWT Auth ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
NETPULSE_JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION

# ── RIPE Atlas ──────────────────────────────────────────────────────
# Get a free API key at: https://atlas.ripe.net/
NETPULSE_RIPE_ATLAS_API_KEY=

# ── Cloudflare Radar ────────────────────────────────────────────────
# Get a free API token at: https://dash.cloudflare.com/profile/api-tokens
NETPULSE_CLOUDFLARE_RADAR_API_TOKEN=

# ── Claude API (Anthropic) ──────────────────────────────────────────
# Get an API key at: https://console.anthropic.com/
NETPULSE_CLAUDE_API_KEY=
NETPULSE_CLAUDE_MAX_CALLS_PER_HOUR=10
